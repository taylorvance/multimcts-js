{
	"name": "multimcts",
	"version": "2.0.0",
	"description": "TypeScript Monte Carlo Tree Search for multi-team games",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./tictactoe": {
			"types": "./dist/examples/tictactoe.d.ts",
			"import": "./dist/examples/tictactoe.js",
			"default": "./dist/examples/tictactoe.js"
		},
		"./connect-four": {
			"types": "./dist/games/connect-four.d.ts",
			"import": "./dist/games/connect-four.js",
			"default": "./dist/games/connect-four.js"
		},
		"./othello": {
			"types": "./dist/games/othello.d.ts",
			"import": "./dist/games/othello.js",
			"default": "./dist/games/othello.js"
		},
		"./hex": {
			"types": "./dist/games/hex.d.ts",
			"import": "./dist/games/hex.js",
			"default": "./dist/games/hex.js"
		},
		"./isolation": {
			"types": "./dist/games/isolation.d.ts",
			"import": "./dist/games/isolation.js",
			"default": "./dist/games/isolation.js"
		},
		"./breakthrough": {
			"types": "./dist/games/breakthrough.d.ts",
			"import": "./dist/games/breakthrough.js",
			"default": "./dist/games/breakthrough.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"arena": "npm run build && node --experimental-strip-types scripts/arena.mjs",
		"compare:arena": "node scripts/compare-arena.mjs",
		"build": "rm -rf dist && tsc -p tsconfig.json",
		"changeset": "changeset",
		"clean": "rm -rf dist node_modules coverage .eslintcache *.tsbuildinfo",
		"prepare": "simple-git-hooks",
		"prepack": "npm run build",
		"precommit": "node scripts/pre-commit-check.mjs",
		"profile:search": "npm run build && node --experimental-strip-types scripts/profile-search.mjs",
		"release": "npm run verify && changeset publish",
		"verify:push": "node scripts/pre-push-check.mjs && npm run verify && node scripts/pre-push-check.mjs",
		"test": "npm run typecheck && node --experimental-strip-types --test tests/index.test.ts",
		"test:dist": "npm run build && node scripts/smoke-test-dist.mjs",
		"typecheck": "tsc -p tsconfig.test.json",
		"verify": "npm run test && npm run test:dist",
		"version-packages": "changeset version && npm install --package-lock-only"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/taylorvance/multimcts-js.git"
	},
	"simple-git-hooks": {
		"pre-commit": "npm run precommit",
		"pre-push": "npm run verify:push"
	},
	"keywords": [
		"MCTS",
		"Monte Carlo Tree Search",
		"AI",
		"Game"
	],
	"author": "Taylor Vance",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/taylorvance/multimcts-js/issues"
	},
	"homepage": "https://github.com/taylorvance/multimcts-js#readme",
	"devDependencies": {
		"@changesets/cli": "^2.29.7",
		"@types/node": "^25.5.0",
		"simple-git-hooks": "^2.13.1",
		"typescript": "^6.0.2"
	}
}
